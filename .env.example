# ----------------------------------------------------------------------------
# Screener environment configuration (copy to .env for local dev; on Railway
# set these as service variables). All values are OPTIONAL — the app runs in
# demo mode with no configuration at all.
# ----------------------------------------------------------------------------

# SQLite database path. On Railway, mount a Volume at /data and keep this default
# so universes/dictionaries/snapshots/settings/keys survive restarts.
# Locally this falls back to ./app.db automatically if /data is not writable.
DB_PATH=/data/app.db

# Master secret used to derive the Fernet key that encrypts API keys at rest.
# If unset, a key is derived/persisted automatically (less secure). Set a strong
# random value in production. Example: python -c "import secrets;print(secrets.token_urlsafe(48))"
APP_SECRET=

# Port (Railway injects $PORT automatically; only needed for some local setups).
PORT=8000

# ----------------------------------------------------------------------------
# Optional LLM provider keys. Env vars take precedence over the encrypted
# SQLite store. Leave blank to disable AI analysis (screen still works fully).
# ----------------------------------------------------------------------------
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
